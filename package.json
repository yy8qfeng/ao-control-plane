{
  "name": "ao-control-plane",
  "version": "0.1.22",
  "private": true,
  "type": "module",
  "description": "Upper-layer requirement design review and structured plan execution control plane for Agent Orchestrator.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "release:commit": "node scripts/release-commit.mjs",
    "ship": "node scripts/release-commit.mjs"
  },
  "bin": {
    "ao-control-plane": "dist/cli.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.19.1",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.15.9"
}
